import java.util.Random;
public class DiceRollSimulator {

	public static void main(String[] args) {
		Random rand = new Random();
		int count = Integer.parseInt(args[0]);
		int[] num1 = new int[6];
		double[] num2 = new double[6];
		
		for(int i = 0 ; i < count ; i++) {
			int rate = rand.nextInt(6)+1;
			if(rate == 1) {
				num1[0]++;
			}else if(rate == 2) {
				num1[1]++;
			}else if(rate == 3) {
				num1[2]++;
			}else if(rate ==4) {
				num1[3]++;
			}else if(rate == 5) {
				num1[4]++;
			}else if(rate == 6) {
				num1[5]++;
			}
		}
		
		
		System.out.println("サイコロを" + count + "回振りました");
		System.out.println();
		
		for(int i = 0 ; i < 6 ; i++) {
			num2[i] = (num1[i] / count)*100;
			System.out.println(i+1 + "の目:" + num1[i] + "回(" + num2[i] + "%)");
		}
		
		
	}
}

		
