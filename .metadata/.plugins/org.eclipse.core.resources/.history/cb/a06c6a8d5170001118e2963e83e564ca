
public class Uriage {

	public static void main(String[] args) {

		int[][] uriage = {
				{ 101, 60, 40, 50, 0 },
				{ 102, 70, 60, 30, 0 },
				{ 201, 50, 30, 100, 0 }
		};
		
		
		for (int i = 0; i < uriage.length; i++) {
		    int sum = 0;
		    for (int j = 1; j = 3; j++) {
		        sum += uriage[i][j];
		    }
		    uriage[i][4] = sum;
		}

		
		
		for (int i = 0; i < uriage.length; i++) {
			for (int j = 0; j < uriage[i].length; j++) {
				System.out.print(" " + uriage[i][j]);
				
			}
			System.out.println();
		}

	}

}
