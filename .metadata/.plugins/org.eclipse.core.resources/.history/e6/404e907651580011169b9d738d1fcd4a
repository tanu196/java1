import java.util.Random;
import java.util.Scanner;
public class Ens34_challenge {

	public static void main(String[] args) {
				Scanner sc = new Scanner(System.in);
				Random random = new Random();
				
				int enemyHp = random.nextInt(15)+5;
				int playerMP = random.nextInt(10);
				int damage = 0;
				
				System.out.println("敵が現れた！");
				System.out.println("敵のHP："+ enemyHp);
				System.out.println("自分のMP：" + playerMP);
				System.out.println("コマンドを選択してください");
				System.out.println("１：通常攻撃");
				System.out.println("２；全力攻撃");
				System.out.println("３：魔法攻撃（MPを７消費）");
				System.out.println("入力　＞　");
				
				
				
				int command = sc.nextInt();
				switch (command) {
				case 1:
					System.out.println("通常攻撃を選択しました！");
					if (random.nextInt(100) < 80) {
						System.out.println("攻撃成功！");
						damage = 10;
					} else {
						System.out.println("攻撃失敗");
						damage =0;
					}
					break;
					
				case 2:
					System.out.println("全力攻撃を選択しました！");
					if (random.nextInt(100) < 50) {
						System.out.println("攻撃に成功！");
						damage = 25;
					} else {
						
						System.out.println("攻撃失敗！");
						damage = 0;
					}
					break;
				
				case 3:
					if(playerMP>=7) {
						System.out.println(playerMP-7);
						damage=200;	
					}else if(playerMP<70) {
						System.out.println("MPが不足しています");
						damage = 0;
					}
				default:
					System.out.println("正しいコマンドを入力してください。");
					damage = 0;
					break;
				}
				System.out.println(enemyHp - damage);
				System.out.println("敵に与えたダメージ：" + damage);
				System.out.println("敵の残りHP：" + enemyHp);
				System.out.println("自分残りMP:" + playerMP);
				if (enemyHp <=0) {
					System.out.println("ゲームクリア！");
				} else {
					System.out.println("ゲームオーバー！");
				}
				sc.close();
				
			}
}

