import java.util.Random;
public class DiceRollSimulator {

	public static void main(String[] args) {
		Random rand = new Random();
		int count = Integer.parseInt(args[0]);
		int rate1 = 0;
		int rate2 = 0;
		int rate3 = 0;
		int rate4 = 0;
		int rate5 = 0;
		int rate6 = 0;
		double num1 = 0;	
		double num2 = 0;
		double num3 = 0;
		double num4 = 0;
		double num5 = 0;
		double num6 = 0;
		
		for(int i = 0 ; i < count ; i++) {
			int rate = rand.nextInt(6)+1;
			if(rate == 1) {
				rate1++;
			}else if(rate == 2) {
				rate2++;
			}else if(rate == 3) {
				rate3++;
			}else if(rate == 4) {
				rate4++;
			}else if(rate == 5) {
				rate5++;
			}else if(rate == 6) {
				rate6++;
			}
		}
		num1 = rate1 / count;
		num2 = rate2 / count;
		num3 = rate3 / count;
		num4 = rate4 / count;
		num5 = rate5 / count;
		num6 = rate6 / count;
		
		System.out.println("サイコロを" + count + "回振りました");
		System.out.println();
		
			System.out.println(1 + "の目：" + rate1 + "回" + "(" +num1 + "%)");
			System.out.println(2 + "の目：" + rate2 + "回" + "(" +num2 + "%)");
			System.out.println(3 + "の目：" + rate3 + "回" + "(" +num3 + "%)");
			System.out.println(4 + "の目：" + rate4 + "回" + "(" +num4 + "%)");
			System.out.println(5 + "の目：" + rate5 + "回" + "(" +num5 + "%)");
			System.out.println(6 + "の目：" + rate6 + "回" + "(" +num6 + "%)");
		
		
		

	}

}
