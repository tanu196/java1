
public class Exp64_2 {

	public static void main(String[] args) {
		String word = new String("apple");
		String empty = new String("");
		
		//isEmptyメソッド
		System.out.println(word.isEmpty());//文字があるかないかの判定で使える
		System.out.println(empty.isEmpty());//文字があるー＞false
		
		//containメソッド
		String word2 = new String("pineapple");
		
		System.out.println(word.contains("apple"));//この単語が入っているかどうかを判定できる
		System.out.println(word.contains("orange"));
		
		//大文字・小文字にするメソッド
		String word3 = new String("PineApple");
		
		System.out.println(word.toUpperCase());
		System.out.println(word.toLowerCase());
		
		String word4 = new String("Pine Apple");
		
		System.out.println(word.substring(0,4));
		System.out.println(word.substring(4)));
	}

}
